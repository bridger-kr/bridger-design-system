{
  "name": "bridger-design-system",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/**' run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint -c _adherence.oxlintrc.json .",
    "pack:dry-run": "pnpm -r --filter './packages/tokens' --filter './packages/react' exec npm pack --dry-run",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "oxlint": "^1.68.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
