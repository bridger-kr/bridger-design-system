{
  "name": "@bridger-kr/tokens",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./css": "./css/index.css",
    "./css/contract": "./css/contract.css",
    "./css/colors": "./css/colors.css",
    "./css/typography": "./css/typography.css",
    "./css/spacing": "./css/spacing.css",
    "./css/base": "./css/base.css",
    "./css/fonts": "./css/fonts.css",
    "./assets/*": "./assets/*",
    "./styles.css": "./css/index.css"
  },
  "files": [
    "dist",
    "css",
    "assets"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  }
}
